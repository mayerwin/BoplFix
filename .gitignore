# Build output. Release artifacts (installer .exe, bundle .zip, plugin .dll) are produced by
# build.ps1 and attached to GitHub Releases, not committed into git history.
bin/
obj/
.vs/
*.user
dist/

# NuGet
.nuget/
packages/

# Installer build scratch + generated SED (regenerated by build.ps1)
installer/_iexpress_src/
installer/_sfxstage/
installer/*.sed

# Logs
*.log

# --- NEVER commit the game's copyrighted binaries to a public repo ---
# (The playable game archive lives outside this repo. These patterns are a safety net
#  in case any game files ever get copied in here.)
BoplBattle.exe
UnityPlayer.dll
*_Data/
**/*vanilla*.zip
**/BoplBattle*.zip
MonoBleedingEdge/

# Decompiled game source + local/private docs - never commit (copyrighted game code, private files)
_re/
*.pdf
